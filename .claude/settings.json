{
  "permissions": {
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/Users/pon00/Projects/forensic-accounting-toolkit/.claude/hooks/session-start.sh"
          },
          {
            "type": "command",
            "command": "python3 -c \"import os, glob, time; files=glob.glob('../krff-shell/01_Data/processed/*.parquet'); stale=[(os.path.basename(f), int((time.time()-os.path.getmtime(f))/86400)) for f in files if time.time()-os.path.getmtime(f)>14*86400]; [print(f'STALE PARQUET: {n} ({d}d old) — consider uv run krff run') for n,d in stale]; print('All parquets fresh.') if not stale and files else None\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash C:/Users/pon00/Projects/forensic-accounting-toolkit/.claude/hooks/knowledge-freshness-check.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 C:/Users/pon00/Projects/forensic-accounting-toolkit/.claude/hooks/pre-guard-destructive.py"
          },
          {
            "type": "command",
            "command": "python3 C:/Users/pon00/Projects/forensic-accounting-toolkit/.claude/hooks/pre-commit-test-guard.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 C:/Users/pon00/Projects/forensic-accounting-toolkit/studio/guardrails/pre_data_raw_guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 C:/Users/pon00/Projects/forensic-accounting-toolkit/.claude/hooks/post-push-reminder.py"
          },
          {
            "type": "command",
            "command": "python3 C:/Users/pon00/Projects/forensic-accounting-toolkit/.claude/hooks/post-commit-test-sync.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 C:/Users/pon00/Projects/forensic-accounting-toolkit/.claude/hooks/post-edit-stale-check.py"
          },
          {
            "type": "command",
            "command": "python3 C:/Users/pon00/Projects/forensic-accounting-toolkit/.claude/hooks/post-edit-sibling-guard.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 C:/Users/pon00/Projects/forensic-accounting-toolkit/.claude/hooks/post-edit-stale-check.py"
          },
          {
            "type": "command",
            "command": "python3 C:/Users/pon00/Projects/forensic-accounting-toolkit/.claude/hooks/post-edit-sibling-guard.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"--- SESSION END CHECK ---\" && bash C:/Users/pon00/Projects/forensic-accounting-toolkit/ecosystem.sh status 2>/dev/null | grep -v OK | head -10 && echo \"---\"'"
          },
          {
            "type": "command",
            "command": "bash C:/Users/pon00/Projects/forensic-accounting-toolkit/.claude/hooks/stop-doc-drift-scan.sh"
          },
          {
            "type": "command",
            "command": "bash C:/Users/pon00/Projects/forensic-accounting-toolkit/.claude/hooks/knowledge-drift-check.sh"
          },
          {
            "type": "command",
            "command": "bash C:/Users/pon00/Projects/forensic-accounting-toolkit/.claude/hooks/stop-board-snapshot.sh"
          }
        ]
      }
    ]
  }
}
